    {
      "parameters": {
        "jsCode": "// Get URL from Pass Through (HTTP Request replaces $json, losing input fields)\nconst upstream = $('Pass Through').first().json;\nconst url = upstream.url || '';\nconst timestamp = upstream.timestamp || new Date().toISOString();\n\nif (!url) {\n  return [{ json: { hasChanged: false, url: 'unknown', skipReason: 'No URL found' } }];\n}\n\n// Get HTML from HTTP response (autodetect mode puts text in 'data' field)\nconst httpRes = $input.first().json;\nconst html = httpRes.data || httpRes.body || httpRes.html ||\n             (typeof httpRes === 'string' ? httpRes : '');\n\nif (!html || html.length < 100) {\n  return [{ json: { hasChanged: false, url, skipReason: 'No/minimal HTML content' } }];\n}\n\n// Strip HTML tags to get text\nlet text = html;\ntext = text.replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '');\ntext = text.replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '');\ntext = text.replace(/<nav[^>]*>[\\s\\S]*?<\\/nav>/gi, '');\ntext = text.replace(/<footer[^>]*>[\\s\\S]*?<\\/footer>/gi, '');\ntext = text.replace(/<header[^>]*>[\\s\\S]*?<\\/header>/gi, '');\n\nconst titleMatch = html.match(/<title[^>]*>([^<]+)<\\/title>/i);\nconst title = titleMatch ? titleMatch[1].trim() : '';\n\ntext = text.replace(/<\\/(p|div|h[1-6]|li|tr|blockquote|section|article)>/gi, '\\n');\ntext = text.replace(/<br\\s*\\/?>/gi, '\\n');\ntext = text.replace(/<li[^>]*>/gi, '• ');\ntext = text.replace(/<[^>]+>/g, ' ');\ntext = text.replace(/&nbsp;/g, ' ');\ntext = text.replace(/&amp;/g, '&');\ntext = text.replace(/&lt;/g, '<');\ntext = text.replace(/&gt;/g, '>');\ntext = text.replace(/&quot;/g, '\"');\ntext = text.replace(/&#39;/g, \"'\");\ntext = text.replace(/&#x([0-9a-f]+);/gi, (_, hex) => String.fromCharCode(parseInt(hex, 16)));\ntext = text.replace(/&#(\\d+);/g, (_, dec) => String.fromCharCode(parseInt(dec)));\ntext = text.replace(/[ \\t]+/g, ' ');\ntext = text.replace(/\\n\\s*\\n/g, '\\n\\n');\ntext = text.trim();\n\nif (text.length < 200) {\n  return [{ json: { hasChanged: false, url, skipReason: 'Extracted text too short (' + text.length + ' chars)' } }];\n}\n\n// Hash the text (cyrb53)\nfunction cyrb53(str) {\n  let h1 = 0xdeadbeef, h2 = 0x41c6ce57;\n  for (let i = 0; i < str.length; i++) {\n    const ch = str.charCodeAt(i);\n    h1 = Math.imul(h1 ^ ch, 2654435761);\n    h2 = Math.imul(h2 ^ ch, 1597334677);\n  }\n  h1 = Math.imul(h1 ^ (h1 >>> 16), 2246822507);\n  h1 ^= Math.imul(h2 ^ (h2 >>> 13), 3266489909);\n  h2 = Math.imul(h2 ^ (h2 >>> 16), 2246822507);\n  h2 ^= Math.imul(h1 ^ (h1 >>> 13), 3266489909);\n  return (4294967296 * (2097151 & h2) + (h1 >>> 0)).toString(16).padStart(14, '0');\n}\n\nconst contentHash = cyrb53(text);\n\n// Compare with stored hash\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.hashes) staticData.hashes = {};\nif (!staticData.stats) staticData.stats = { changed: 0, skipped: 0 };\n\nconst previousHash = staticData.hashes[url] || null;\nconst hasChanged = previousHash !== contentHash;\n\nif (hasChanged) {\n  staticData.hashes[url] = contentHash;\n  staticData.stats.changed++;\n} else {\n  staticData.stats.skipped++;\n}\n\nreturn [{\n  json: {\n    url, title, text, contentHash,\n    contentLength: text.length,\n    timestamp,\n    hasChanged,\n    previousHash,\n    fetchedAt: new Date().toISOString()\n  }\n}];"
