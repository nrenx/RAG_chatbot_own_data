        "jsCode": "// Get URL and hash from Extract & Detect Change node\n// (Qdrant Vector Store replaces $json with its own output)\nconst extracted = $('Extract & Detect Change').first().json;\nconst url = extracted.url;\nconst versionId = extracted.contentHash.substring(0, 12);\n\nreturn [{\n  json: {\n    url,\n    versionId,\n    deleteBody: JSON.stringify({\n      filter: {\n        must: [{ key: 'metadata.source', match: { value: url } }],\n        must_not: [{ key: 'metadata.versionId', match: { value: versionId } }]\n      }\n    })\n  }\n}];"
